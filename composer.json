{
  "name": "helip/siel-esahr-client",
  "description": "Client for Siel ESAHR API (REST v1.5.18)",
  "type": "library",
  "version": "1.0.0",
  "license": "LGPL-3.0",
  "require": {
    "php": "^8.2",
    "helip/niss": "^2.0",
    "symfony/http-client": "^6.0"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1",
    "friendsofphp/php-cs-fixer": "^3.45",
    "phpcompatibility/php-compatibility": "^10@dev",
    "phpmd/phpmd": "^2.15",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^10",
    "squizlabs/php_codesniffer": "^3",
    "vlucas/phpdotenv": "^5.5"
  },
  "autoload": {
    "psr-4": {
      "Helip\\SielEsahrClient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Helip\\SielEsahrClient\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "find src tests -type f -name '*.php' -print0 | xargs -0 -n1 -P4 php -l",
    "cs-check": "php-cs-fixer fix --dry-run --diff src",
    "cs-fix": "php-cs-fixer fix src",
    "psr12-check": "phpcs --standard=PSR12 --warning-severity=0 src tests",
    "psr12-fix": "phpcbf --standard=PSR12 src tests",
    "stan": "phpstan analyse --no-progress --memory-limit=2G -c phpstan.neon src",
    "phpmd-text": "php -d error_reporting='E_ALL & ~E_DEPRECATED' vendor/bin/phpmd src,tests text phpmd.xml --minimumpriority 3",
    "phpmd-html": "mkdir -p build && php -d error_reporting='E_ALL & ~E_DEPRECATED' vendor/bin/phpmd src,tests html phpmd.xml --reportfile build/phpmd.html --minimumpriority 3",
    "phpcompat": "phpcs -p --standard=PHPCompatibility --runtime-set testVersion 8.2- src",
    "test": "XDEBUG_MODE=coverage phpunit --colors=always --log-junit build/junit.xml",
    "coverage": "XDEBUG_MODE=coverage phpunit --colors=never --coverage-clover build/coverage.xml",
    "fix": [
      "@psr12-fix",
      "@cs-fix"
    ],
    "qa": [
      "@lint",
      "@cs-check",
      "@psr12-check",
      "@stan",
      "@phpmd-text",
      "@phpcompat",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "authors": [
    {
      "name": "Pierre Helin",
      "email": "pierre.helin@gmail.com"
    }
  ],
  "support": {
    "email": "support@helip.be",
    "issues": "https://github.com/helip/siel-esahr-client/issues",
    "source": "https://github.com/helip/siel-esahr-client"
  }
}
